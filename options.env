# ═══════════════════════════════════════════════════════════════════════
# ARKHE OPTIONS — Feature Checklist
# ═══════════════════════════════════════════════════════════════════════
#
# This file controls WHAT runs.
# .env controls HOW it runs (API keys, providers, models).
#
# Set any option to true/false to enable or disable it.
# Future GUI will read this file directly as its checklist state.
# ═══════════════════════════════════════════════════════════════════════


# ── Core Outputs ──────────────────────────────────────────────────────
# CODEBASE_MAP.md — AI narrative: architecture, data flows, module guide
CODEBASE_MAP_ENABLED=true

# DEPENDENCY_MAP.html — interactive D3 file dependency visualization
DEPENDENCY_MAP_ENABLED=true

# EXECUTIVE_REPORT.docx — Word report for stakeholders and engineering leads
EXECUTIVE_REPORT_ENABLED=true


# ── Analysis Speed ────────────────────────────────────────────────────
# thorough = full LLM pass per file — highest quality output
# fast     = batch small files, skip well-documented ones (5-10x faster)
ANALYSIS_SPEED=thorough


# ── Refactor Clone ────────────────────────────────────────────────────
# Generates <repo>_refactored/ with improved docs and code style.
# Original files are NEVER modified. Safe to run at any time.
REFACTOR_ENABLED=false
REFACTOR_SPEED=fast             # thorough | fast


# ── PR Impact Analysis ────────────────────────────────────────────────
# Traces which files are downstream of recently changed files.
# Shows what's affected, what changed, and risk level.
# Generates docs/PR_IMPACT.md — requires git history in the repo.
PR_ANALYSIS_ENABLED=false
PR_BASE_BRANCH=main             # branch to diff against


# ── Security Audit ────────────────────────────────────────────────────
# LLM pass scanning for OWASP Top 10: hardcoded secrets, injection
# risks, missing auth, insecure deserialization, weak crypto, and more.
# Generates docs/SECURITY_REPORT.md
SECURITY_AUDIT_ENABLED=false


# ── Dead Code Detection ───────────────────────────────────────────────
# Static analysis — finds functions and classes defined but never
# referenced anywhere else in the codebase. Zero LLM cost.
# Generates docs/DEAD_CODE_REPORT.md
DEAD_CODE_DETECTION_ENABLED=false


# ── Test Gap Analysis ─────────────────────────────────────────────────
# Identifies public functions with no test coverage.
# Generates docs/TEST_GAP_REPORT.md
TEST_GAP_ANALYSIS_ENABLED=false

# Generate pytest scaffold files for all uncovered functions.
# Only runs when TEST_GAP_ANALYSIS_ENABLED=true.
# Writes to <repo>/tests_generated/
TEST_SCAFFOLDING_ENABLED=false


# ── Complexity Heatmap ────────────────────────────────────────────────
# Overlays complexity scores on the dependency map nodes.
# Red = complex/high-risk, green = simple/low-risk.
# Score = token count + import coupling + function density. Zero LLM cost.
COMPLEXITY_HEATMAP_ENABLED=false
