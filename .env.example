# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Active Provider per Agent Role ────────────────────────────
# Options: groq | gemini | anthropic
TRAVERSAL_PROVIDER=groq
REPORT_PROVIDER=gemini
EXECUTIVE_PROVIDER=anthropic
REFACTOR_PROVIDER=groq     # Provider for the refactor clone pass (per-file, always cheap model)

# ── Cost gate ─────────────────────────────────────────────────
# false (default) → all roles use cheap models — safe for testing / free-tier runs
# true            → synthesis uses Sonnet; executive report uses Opus (large repo)
#                   or Sonnet (small repo). Traversal always stays cheap.
EXPENSIVE_MODELS_ALLOWED=false
REFACTOR_ENABLED=false         # Set to true to auto-generate a refactored clone on every run
REFACTOR_SPEED=thorough        # thorough = full per-file pass | fast = batch + skip documented + higher concurrency

# Token threshold above which a repo is considered "large" (Opus vs Sonnet for report)
COMPLEXITY_THRESHOLD_TOKENS=50000

# ── Model overrides (leave blank to use defaults from settings.py) ──
TRAVERSAL_MODEL=
REPORT_MODEL=
EXECUTIVE_MODEL=
REFACTOR_MODEL=
REFACTOR_CONCURRENCY=    # Override concurrent file limit (default: 1 groq, 5 gemini, 3 anthropic)
