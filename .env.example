# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Active Provider per Agent Role ────────────────────────────
# Options: groq | gemini | anthropic
TRAVERSAL_PROVIDER=groq
REPORT_PROVIDER=gemini
EXECUTIVE_PROVIDER=anthropic

# ── Cost gate ─────────────────────────────────────────────────
# false (default) → all roles use cheap models — safe for testing / free-tier runs
# true            → synthesis uses Sonnet; executive report uses Opus (large repo)
#                   or Sonnet (small repo). Traversal always stays cheap.
EXPENSIVE_MODELS_ALLOWED=false

# Token threshold above which a repo is considered "large" (Opus vs Sonnet for report)
COMPLEXITY_THRESHOLD_TOKENS=50000

# ── Model overrides (leave blank to use defaults from settings.py) ──
TRAVERSAL_MODEL=
REPORT_MODEL=
EXECUTIVE_MODEL=
