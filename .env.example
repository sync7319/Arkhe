# ── API Keys ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Active Provider per Agent Role ────────────────────────────
# Options: groq | gemini | anthropic
TRAVERSAL_PROVIDER=groq
REPORT_PROVIDER=gemini

# ── Model overrides (leave blank to use defaults from settings.py) ──
TRAVERSAL_MODEL=
REPORT_MODEL=
