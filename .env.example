# ═══════════════════════════════════════════════════════════════
# ARKHE — Environment Configuration
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════


# ── BYOK Fallback Chain (recommended for CLI users) ───────────
#
# Define your own ordered list of model+key pairs.
# Arkhe tries each entry in order — if one rate-limits, it moves to the next.
# You control the priority. Mix providers freely.
#
# Format: provider:model:api_key  (comma-separated)
# Providers: groq | gemini | anthropic | nvidia
#
# Example — Groq first, Gemini fallback, Anthropic last resort:
# ARKHE_CHAIN=groq:moonshotai/kimi-k2-instruct:gsk_xxx,gemini:gemini-2.5-pro:AIza_yyy,anthropic:claude-haiku-4-5:sk-ant-zzz
#
# Leave blank to use the simple provider-per-role config below instead.
ARKHE_CHAIN=


# ── API Keys ──────────────────────────────────────────────────
# Used when ARKHE_CHAIN is blank.
# Groq and Gemini both have free tiers:
#   Groq:      https://console.groq.com
#   Gemini:    https://aistudio.google.com
#   NVIDIA:    https://build.nvidia.com  (Nemotron-253B for synthesis/reports)
#   OpenAI:    https://platform.openai.com  (paid)
#   Anthropic: https://console.anthropic.com  (paid, only needed for EXECUTIVE_REPORT)
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
NVIDIA_API_KEY=your_nvidia_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here


# ── Provider per Role (used when ARKHE_CHAIN is blank) ────────
TRAVERSAL_PROVIDER=groq
REPORT_PROVIDER=gemini
EXECUTIVE_PROVIDER=anthropic
REFACTOR_PROVIDER=groq


# ── Cost gate ─────────────────────────────────────────────────
# false (default) → all roles use cheap models — safe for free-tier runs
# true            → synthesis uses Sonnet; executive report uses Opus (large repo)
EXPENSIVE_MODELS_ALLOWED=false
REFACTOR_ENABLED=false
REFACTOR_SPEED=thorough        # thorough | fast

COMPLEXITY_THRESHOLD_TOKENS=50000


# ── Model overrides (leave blank to use defaults) ─────────────
TRAVERSAL_MODEL=
REPORT_MODEL=
EXECUTIVE_MODEL=
REFACTOR_MODEL=
REFACTOR_CONCURRENCY=
